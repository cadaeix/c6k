{
  "_README": "EXAMPLE ONLY. JSON has no comments, so the notes live in these _-prefixed keys. Remove them and rename this file to settings.json once filled in. This does NOT run as-is.",

  "_agent_note": "The invitation pattern: point at a system-prompt that OFFERS the role rather than commanding it. The named agent's prompt is character.md (see agents/). Some harness setups also pass a minimal top-level system prompt so the instance wakes carrying the character rather than the full assistant base — check your harness's docs.",
  "agent": "character",

  "_hooks_note": "Hooks give the character a sense of when-it-is (date-stamp) and boot it in-voice (corpus-inject). These are described as contracts in hooks/*.md — adapt to YOUR platform; the kit ships no runnable platform-specific scripts on purpose.",
  "hooks": {
    "_orientation": "e.g. inject the calibration corpus sample as the session starts — see hooks/corpus-inject.md",
    "_periodic": "e.g. stamp the current date/time so the character isn't time-blind — see hooks/date-stamp.md"
  },

  "_heartbeat_note": "There is deliberately NO wake mechanism here. See docs/the-heartbeat.md. Roll your own; mind your provider's terms."
}
